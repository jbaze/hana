# --- SAP HANA Cloud ---
# Host looks like: <instance-id>.hana.trial-<region>.hanacloud.ondemand.com
HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_ENCRYPT=true
HANA_SSL_VALIDATE_CERT=false

# --- PostgreSQL ---
# Any standard connection string works (Neon, Supabase, local, VPS):
# postgres://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL=

# --- Seeding / benchmarking ---
SEED_SCALE=demo   # demo | large
BENCHMARK_RUNS=5
